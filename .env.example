# Minimum discount percentage to report (e.g. 30 means >= 30% off)
ZARA_DISCOUNT_THRESHOLD=30

# Zara JP API base URL
ZARA_BASE_URL=https://www.zara.com/jp/ja

# HTTP request settings
ZARA_REQUEST_TIMEOUT=30
ZARA_REQUEST_DELAY=0.5

# Maximum number of concurrent category fetches (higher = faster but more aggressive)
ZARA_CONCURRENCY=10

# Telegram notification (leave empty to disable)
ZARA_TG_BOT_TOKEN=
ZARA_TG_CHAT_ID=
